{
  "name": "oh-my-qoder",
  "version": "0.1.0",
  "description": "Multi-agent orchestration system for Qoder CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "oh-my-qoder": "bin/oh-my-qoder.js",
    "omq": "bin/oh-my-qoder.js",
    "omq-cli": "bridge/cli.cjs"
  },
  "files": [
    "dist",
    "agents",
    "bin",
    "bridge",
    "commands",
    "hooks",
    "scripts",
    "skills",
    "templates",
    "docs",
    ".qoder-plugin",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-mcp-server.mjs && npm run compose-docs",
    "compose-docs": "node scripts/compose-docs.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build && npm run compose-docs"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.31.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@qoder-ai/qoder-agent-sdk": "^1.0.11",
    "@types/better-sqlite3": "^7.6.13",
    "ajv": "^8.17.1",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "jsonc-parser": "^3.3.1",
    "safe-regex": "^2.1.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "esbuild": "^0.27.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "author": "oh-my-qoder contributors",
  "license": "Apache-2.0",
  "keywords": [
    "qoder",
    "qoder-cli",
    "ai",
    "agent",
    "multi-agent",
    "orchestration",
    "omq"
  ],
  "publishConfig": {
    "access": "public"
  }
}
