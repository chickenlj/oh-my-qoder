{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/keyword-detector.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/skill-injector.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/session-start.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/project-memory-session.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/wiki-session-start.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/setup-init.mjs",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/setup-maintenance.mjs",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/pre-tool-enforcer.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/permission-handler.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/post-tool-verifier.mjs",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/project-memory-posttool.mjs",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/post-tool-rules-injector.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/post-tool-use-failure.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/subagent-tracker.mjs start",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/subagent-tracker.mjs stop",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/verify-deliverables.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/pre-compact.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/project-memory-precompact.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/wiki-pre-compact.mjs",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/context-guard-stop.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/persistent-mode.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/code-simplifier.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/session-end.mjs",
            "timeout": 30,
            "async": true
          },
          {
            "type": "command",
            "command": "node \"$QODER_PLUGIN_ROOT\"/scripts/run.cjs \"$QODER_PLUGIN_ROOT\"/scripts/wiki-session-end.mjs",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ]
  }
}
